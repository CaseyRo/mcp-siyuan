# SiYuan kernel API token (same as SIYUAN_ACCESS_AUTH_CODE)
SIYUAN_TOKEN=

# SiYuan kernel URL (default: http://siyuan:6806 in Docker)
# SIYUAN_URL=http://siyuan:6806

# MCP transport: "http" (default in Docker) or "stdio" (for Claude Code)
# TRANSPORT=http

# MCP server authentication
# API key for bearer token auth (auto-generated if empty)
# MCP_SIYUAN_API_KEY=smcp_...

# Public HTTPS URL (required for Claude.ai OAuth discovery)
# MCP_SIYUAN_PUBLIC_URL=https://mcp-siyuan.cdit-dev.de

# Keycloak JWT validation
# KEYCLOAK_ISSUER=https://auth.cdit-works.de/realms/cdit-mcp
# KEYCLOAK_AUDIENCE=mcp-siyuan
