# Example environment for mcp-siyuan.
# All variables are read by mcp_siyuan/config.py (pydantic-settings, no prefix).
# Copy to .env for local development; inject via your secret store in production.

# --- SiYuan kernel connection ---

# SiYuan kernel API token (from SiYuan: Settings -> About -> API token).
# Server warns at startup if unset; calls will be unauthenticated.
SIYUAN_TOKEN=

# SiYuan kernel URL. Must be http:// or https://.
# Default assumes the sidecar pattern (SiYuan reachable on the same network).
# SIYUAN_URL=http://siyuan:6806

# --- Server transport ---

# Transport: "stdio" (default, for local Claude Code) or "http" (remote clients).
# TRANSPORT=stdio

# Bind host/port for HTTP mode. Container deploys typically bind 0.0.0.0.
# HOST=127.0.0.1
# PORT=8000

# Bearer token for HTTP mode. REQUIRED when TRANSPORT=http — the server
# refuses to start without it. Generate one with: openssl rand -hex 32
# MCP_API_KEY=

# --- Observability & reliability ---

# SIYUAN_LOG_LEVEL=INFO
# SIYUAN_DIAG_BUFFER_SIZE=50
# SIYUAN_IDEMPOTENCY_TTL_SECONDS=300
# UPSTREAM_PROBE_INTERVAL=30

# Transient-failure retry (5xx / transport errors).
# SIYUAN_RETRY_MAX_ATTEMPTS=3
# SIYUAN_RETRY_INITIAL_BACKOFF=0.25
# SIYUAN_RETRY_MAX_BACKOFF=2.0
